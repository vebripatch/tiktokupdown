<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TikSave - TikTok Downloader Premium, Batch & Username</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="favicon.png">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0b0f19;
        }
        .tiktok-gradient {
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
        }
        .tiktok-btn-gradient {
            background: linear-gradient(90deg, #ff0050 0%, #00f2fe 100%);
        }
        .glass {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 8px;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 8px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        /* Custom date picker styling */
        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
            cursor: pointer;
        }
        /* Hide scrollbar for TikTok-like feed modal */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="text-gray-100 min-h-screen flex flex-col justify-between">

    <!-- Header Navigation -->
    <header class="glass sticky top-0 z-40 px-6 py-4 border-b border-gray-800">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="p-2.5 bg-gradient-to-tr from-pink-600 to-cyan-500 rounded-xl flex items-center justify-center shadow-lg shadow-pink-500/20">
                    <i data-lucide="video" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-white via-gray-200 to-pink-500 bg-clip-text text-transparent">TikSave</span>
                    <span class="text-xs block text-cyan-400 font-semibold tracking-wider uppercase">Multi & Username Downloader</span>
                </div>
            </div>
            <nav class="hidden md:flex items-center space-x-6">
                <a href="#downloader" class="text-sm font-medium text-gray-300 hover:text-white transition-colors">Downloader</a>
                <a href="#fitur" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Fitur</a>
            </nav>
            <div class="flex items-center space-x-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-500/10 text-purple-400 border border-purple-500/20 mr-2">
                    <i data-lucide="sparkles" class="w-3 h-3 mr-1"></i>
                    AI FYP
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
                    <span class="w-1.5 h-1.5 mr-1.5 bg-green-400 rounded-full animate-pulse"></span>
                    API Online
                </span>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-6xl w-full mx-auto px-4 py-8 md:py-12 pb-32">
        
        <!-- Hero Section -->
        <div class="text-center mb-8">
            <h1 class="text-3xl md:text-5xl font-extrabold mb-3 tracking-tight leading-none">
                Download Video TikTok <br class="hidden md:block"> 
                <span class="bg-gradient-to-r from-pink-500 via-purple-400 to-cyan-400 bg-clip-text text-transparent">Tanpa Watermark</span>
            </h1>
            <p class="text-gray-400 text-sm md:text-base max-w-xl mx-auto">
                Unduh video tunggal, daftar tautan massal, atau langsung <b>jelajahi semua video berdasarkan Username</b> dengan pilihan seleksi video interaktif secara massal.
            </p>
        </div>

        <!-- Downloader Container with Tabs -->
        <div id="downloader" class="glass rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden mb-8">
            <!-- Decorative Light Effects -->
            <div class="absolute -top-12 -left-12 w-32 h-32 bg-pink-500 rounded-full blur-3xl opacity-15"></div>
            <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-cyan-500 rounded-full blur-3xl opacity-15"></div>

            <!-- Tab Switcher Header (3 Tabs) -->
            <div class="flex flex-wrap border-b border-gray-800/80 mb-6 relative z-10 gap-y-2">
                <button onclick="switchTab('single')" id="tabSingleBtn" class="flex-1 min-w-[120px] pb-3 text-center font-bold text-sm border-b-2 border-pink-500 text-pink-500 transition-all flex items-center justify-center space-x-2">
                    <i data-lucide="video" class="w-4 h-4"></i>
                    <span>Tunggal</span>
                </button>
                <button onclick="switchTab('batch')" id="tabBatchBtn" class="flex-1 min-w-[120px] pb-3 text-center font-bold text-sm border-b-2 border-transparent text-gray-400 hover:text-gray-200 transition-all flex items-center justify-center space-x-2">
                    <i data-lucide="layers" class="w-4 h-4"></i>
                    <span>Banyak (Batch)</span>
                </button>
                <button onclick="switchTab('username')" id="tabUsernameBtn" class="flex-1 min-w-[120px] pb-3 text-center font-bold text-sm border-b-2 border-transparent text-gray-400 hover:text-gray-200 transition-all flex items-center justify-center space-x-2">
                    <i data-lucide="user" class="w-4 h-4"></i>
                    <span>Cari Username</span>
                </button>
            </div>

            <!-- TAB 1: Single Link Downloader -->
            <div id="tabSingleContent" class="relative z-10">
                <div class="flex flex-col md:flex-row gap-3">
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-500">
                            <i data-lucide="link-2" class="w-5 h-5"></i>
                        </div>
                        <input type="text" id="tiktokUrl" placeholder="Tempel URL Video (https://...) atau masukkan ID Video saja" 
                               class="w-full pl-12 pr-12 py-4 bg-gray-900/80 border border-gray-700/60 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all text-sm md:text-base">
                        <button onclick="clearSingleInput()" id="clearBtn" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-500 hover:text-white hidden">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <button onclick="processSingleVideo()" class="tiktok-btn-gradient hover:opacity-90 text-white font-bold py-4 px-8 rounded-2xl flex items-center justify-center space-x-2 shadow-lg shadow-pink-500/15 transition-all transform hover:scale-[1.02] active:scale-[0.98]">
                        <i data-lucide="search" class="w-5 h-5"></i>
                        <span>Proses Video</span>
                    </button>
                </div>
                <div class="mt-3 flex justify-between items-center px-1">
                    <p class="text-xs text-gray-500">Mendukung link vt.tiktok, tiktok.com, maupun ID Video angka.</p>
                    <button onclick="pasteToInput('tiktokUrl', 'clearBtn')" class="text-xs font-semibold text-cyan-400 hover:text-cyan-300 flex items-center space-x-1">
                        <i data-lucide="clipboard" class="w-3.5 h-3.5"></i>
                        <span>Tempel Clipboard</span>
                    </button>
                </div>
            </div>

            <!-- TAB 2: Batch Link Downloader -->
            <div id="tabBatchContent" class="relative z-10 hidden">
                <p class="text-xs text-gray-400 mb-3">Masukkan beberapa tautan video atau ID video di bawah ini (Satu per baris):</p>
                <div class="relative mb-3">
                    <textarea id="tiktokBatchUrls" rows="6" placeholder="https://vt.tiktok.com/ZS8fxxA9/&#10;7312345678901234567&#10;https://www.tiktok.com/@user/video/73987654321" 
                              class="w-full p-4 bg-gray-900/80 border border-gray-700/60 rounded-2xl text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all text-sm font-mono"></textarea>
                    <button onclick="clearBatchInput()" id="clearBatchBtn" class="absolute top-4 right-4 text-gray-500 hover:text-white hidden">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                </div>
                <div class="flex flex-col sm:flex-row justify-between items-stretch sm:items-center gap-3">
                    <button onclick="pasteToTextarea()" class="text-xs font-semibold text-cyan-400 hover:text-cyan-300 flex items-center justify-center sm:justify-start space-x-1">
                        <i data-lucide="clipboard" class="w-4 h-4"></i>
                        <span>Tempel Teks Massal</span>
                    </button>
                    <button onclick="processBatchVideos()" class="bg-gradient-to-r from-pink-600 to-purple-600 hover:opacity-95 text-white font-bold py-3.5 px-8 rounded-2xl flex items-center justify-center space-x-2 shadow-lg transition-all transform hover:scale-[1.01] active:scale-[0.99]">
                        <i data-lucide="play" class="w-5 h-5"></i>
                        <span>Proses Semua Data</span>
                    </button>
                </div>
            </div>

            <!-- TAB 3: Username Downloader with Settings -->
            <div id="tabUsernameContent" class="relative z-10 hidden">
                <div class="flex flex-col md:flex-row gap-3">
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-500">
                            <i data-lucide="user" class="w-5 h-5"></i>
                        </div>
                        <input type="text" id="tiktokUsername" placeholder="Masukkan Username TikTok saja (contoh: khaby.lame)" 
                               class="w-full pl-12 pr-12 py-4 bg-gray-900/80 border border-gray-700/60 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all text-sm md:text-base">
                        <button onclick="clearUsernameInput()" id="clearUserBtn" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-500 hover:text-white hidden">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                    
                    <!-- Dropdown Limit Halaman -->
                    <div class="relative min-w-[150px]">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-cyan-400">
                            <i data-lucide="list-ordered" class="w-4 h-4"></i>
                        </div>
                        <select id="usernameLimit" onchange="resetUsernamePagination()" class="w-full pl-10 pr-8 py-4 bg-gray-900/80 border border-gray-700/60 rounded-2xl text-white appearance-none focus:outline-none focus:ring-2 focus:ring-cyan-500 transition-all text-sm font-semibold cursor-pointer">
                            <option value="10">10 Posting</option>
                            <option value="20" selected>20 Posting</option>
                            <option value="30">30 Posting</option>
                            <option value="50">50 Posting</option>
                            <option value="100">100 Posting</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-gray-500">
                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                        </div>
                    </div>

                    <button onclick="processUsernameVideos(true)" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:opacity-90 text-white font-bold py-4 px-8 rounded-2xl flex items-center justify-center space-x-2 shadow-lg shadow-cyan-500/15 transition-all transform hover:scale-[1.02] active:scale-[0.98]">
                        <i data-lucide="search" class="w-5 h-5"></i>
                        <span>Cari Video</span>
                    </button>
                </div>
                <div class="mt-3 flex justify-between items-center px-1">
                    <p class="text-xs text-gray-500">Sistem akan menyajikan daftar video per halaman sesuai jumlah yang diatur.</p>
                    <button onclick="pasteToInput('tiktokUsername', 'clearUserBtn')" class="text-xs font-semibold text-cyan-400 hover:text-cyan-300 flex items-center space-x-1">
                        <i data-lucide="clipboard" class="w-3.5 h-3.5"></i>
                        <span>Tempel Username</span>
                    </button>
                </div>
            </div>

            <!-- Shared Loading State -->
            <div id="loadingState" class="hidden mt-8 text-center py-6">
                <div class="inline-block relative w-16 h-16">
                    <div class="absolute inset-0 rounded-full border-4 border-gray-800"></div>
                    <div class="absolute inset-0 rounded-full border-4 border-t-pink-500 border-r-cyan-400 animate-spin"></div>
                </div>
                <p id="loadingMessage" class="mt-4 text-gray-300 font-medium">Menganalisis data video...</p>
                <!-- Progress Bar for Batch Downloader -->
                <div id="batchProgressBarContainer" class="max-w-xs mx-auto mt-4 bg-gray-800 rounded-full h-2.5 overflow-hidden hidden">
                    <div id="batchProgressBar" class="bg-gradient-to-r from-pink-500 to-cyan-400 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
                <p id="batchProgressText" class="text-xs text-gray-500 mt-2 hidden">Memproses 0 dari 0 data</p>
            </div>

            <!-- Error State -->
            <div id="errorState" class="hidden mt-6 p-4 bg-red-900/20 border border-red-500/30 rounded-2xl flex items-start space-x-3">
                <div class="p-1 bg-red-500/20 rounded-lg text-red-400">
                    <i data-lucide="alert-circle" class="w-5 h-5"></i>
                </div>
                <div>
                    <h4 class="text-sm font-bold text-red-400">Terjadi Kesalahan</h4>
                    <p class="text-xs text-gray-400 mt-0.5" id="errorMessage">Pastikan input Anda sudah benar.</p>
                </div>
            </div>

            <!-- Single Result State -->
            <div id="resultState" class="hidden mt-8 pt-8 border-t border-gray-800/80">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                    <!-- Video Preview Card -->
                    <div class="md:col-span-5 flex flex-col items-center">
                        <div class="relative w-full max-w-[240px] aspect-[9/16] bg-black rounded-2xl overflow-hidden shadow-2xl border border-gray-800 group">
                            <video id="videoPreview" class="w-full h-full object-cover" controls playsinline loop crossorigin="anonymous">
                                <source id="videoSource" src="" type="video/mp4">
                                Browser Anda tidak mendukung pemutaran video langsung.
                            </video>
                            <span class="absolute top-3 right-3 bg-black/60 backdrop-blur text-[10px] font-bold px-2 py-1 rounded-full text-white tracking-widest uppercase">Pratinjau Asli</span>
                        </div>
                        <p class="text-xs text-gray-500 mt-2 italic text-center">Pratinjau asli berhasil dimuat.</p>
                    </div>

                    <!-- Meta & Actions -->
                    <div class="md:col-span-7 flex flex-col justify-between">
                        <div>
                            <!-- Creator Info -->
                            <div class="flex items-center space-x-3 mb-4">
                                <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-pink-600 to-cyan-400 p-0.5 overflow-hidden">
                                    <img id="creatorAvatar" src="" class="w-full h-full rounded-full object-cover" onerror="this.src='https://api.dicebear.com/7.x/bottts/svg?seed=tiktok'">
                                </div>
                                <div>
                                    <h4 id="creatorName" class="font-bold text-white text-base">@username</h4>
                                    <div class="flex items-center gap-3 mt-0.5">
                                        <p class="text-xs text-gray-400 flex items-center gap-1">
                                            <i data-lucide="calendar" class="w-3.5 h-3.5 text-cyan-400"></i>
                                            <span id="videoPublishDate">Diposting: -</span>
                                        </p>
                                        <!-- FOLLOWER BADGE NEW -->
                                        <p id="singleCreatorFollowersContainer" class="text-xs text-emerald-400 font-semibold flex items-center gap-1 hidden bg-emerald-500/10 px-1.5 py-0.5 rounded border border-emerald-500/20">
                                            <i data-lucide="users" class="w-3 h-3"></i>
                                            <span id="singleCreatorFollowers">0</span>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Title / Caption -->
                            <p id="videoTitle" class="text-gray-200 text-sm leading-relaxed mb-4">
                                Deskripsi video akan tampil di sini...
                            </p>

                            <!-- Video Stats -->
                            <div class="grid grid-cols-4 gap-2 mb-6">
                                <div class="bg-gray-900/50 p-2.5 rounded-xl border border-gray-800 text-center">
                                    <span class="text-[10px] text-gray-500 block mb-0.5">Dilihat</span>
                                    <span id="statViews" class="text-xs font-bold text-emerald-400">0</span>
                                </div>
                                <div class="bg-gray-900/50 p-2.5 rounded-xl border border-gray-800 text-center">
                                    <span class="text-[10px] text-gray-500 block mb-0.5">Suka</span>
                                    <span id="statLikes" class="text-xs font-bold text-pink-500">0</span>
                                </div>
                                <div class="bg-gray-900/50 p-2.5 rounded-xl border border-gray-800 text-center">
                                    <span class="text-[10px] text-gray-500 block mb-0.5">Komentar</span>
                                    <span id="statComments" class="text-xs font-bold text-cyan-400">0</span>
                                </div>
                                <div class="bg-gray-900/50 p-2.5 rounded-xl border border-gray-800 text-center">
                                    <span class="text-[10px] text-gray-500 block mb-0.5">Bagikan</span>
                                    <span id="statShares" class="text-xs font-bold text-purple-400">0</span>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="space-y-3">
                            <button id="downloadNoWmBtn" onclick="downloadFile(activeData, 'no-wm')" class="w-full bg-gradient-to-r from-emerald-500 to-green-600 hover:opacity-90 text-white font-bold py-3.5 px-4 rounded-xl flex items-center justify-center space-x-2 shadow-lg shadow-emerald-500/15 transition-all">
                                <i data-lucide="shield-check" class="w-5 h-5"></i>
                                <span>Unduh Tanpa Watermark (HD)</span>
                            </button>
                            <button id="downloadWmBtn" onclick="downloadFile(activeData, 'wm')" class="w-full bg-gray-800 hover:bg-gray-700 text-gray-200 font-semibold py-3 px-4 rounded-xl flex items-center justify-center space-x-2 transition-all">
                                <i data-lucide="video" class="w-5 h-5"></i>
                                <span>Unduh Dengan Watermark</span>
                            </button>
                            <button id="downloadAudioBtn" onclick="downloadFile(activeData, 'audio')" class="w-full bg-cyan-900/30 hover:bg-cyan-900/40 text-cyan-400 border border-cyan-500/20 font-semibold py-3 px-4 rounded-xl flex items-center justify-center space-x-2 transition-all">
                                <i data-lucide="music" class="w-5 h-5"></i>
                                <span>Unduh Musik MP3</span>
                            </button>
                            <button id="analyzeAIBtn" onclick="analyzeFYP(encodeURIComponent(JSON.stringify(activeData)))" class="w-full bg-purple-900/30 hover:bg-purple-900/40 text-purple-400 border border-purple-500/20 font-semibold py-3 px-4 rounded-xl flex items-center justify-center space-x-2 transition-all">
                                <i data-lucide="sparkles" class="w-5 h-5"></i>
                                <span>Analisis AI FYP</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Batch & Username Result State -->
            <div id="batchResultState" class="hidden mt-8 pt-8 border-t border-gray-800/80">
                
                <!-- Creator Profile Card -->
                <div id="creatorProfileSection" class="hidden bg-gray-900/60 border border-gray-800 p-5 rounded-3xl mb-6 flex flex-col sm:flex-row items-center gap-5">
                    <img id="userAvatar" src="" class="w-20 h-20 rounded-full object-cover border-2 border-cyan-400 shadow-xl shadow-cyan-500/15">
                    <div class="text-center sm:text-left">
                        <h2 id="userNickname" class="text-lg font-extrabold text-white">Nama Kreator</h2>
                        <div class="flex items-center justify-center sm:justify-start space-x-3 mt-1">
                            <p id="userUniqueId" class="text-sm text-cyan-400 font-semibold">@username</p>
                            <!-- FOLLOWER BADGE NEW -->
                            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                                <i data-lucide="users" class="w-3 h-3 mr-1"></i>
                                <span id="userFollowers">0</span> Pengikut
                            </span>
                        </div>
                        <p class="text-xs text-gray-400 mt-2 max-w-md" id="userSignature">Bio atau deskripsi profil.</p>
                    </div>
                </div>

                <!-- Header Control dengan Filter Tanggal, Pencarian Caption, & Pilihan Layout -->
                <div class="flex flex-col lg:flex-row justify-between items-stretch lg:items-center gap-4 mb-6 bg-gray-900/40 p-4 rounded-2xl border border-gray-800/60">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 flex-grow">
                        <div>
                            <h3 class="text-base font-bold flex items-center space-x-2 text-white">
                                <span class="bg-pink-500 text-white text-xs px-2.5 py-1 rounded-full" id="batchSuccessCount">0 Video</span>
                                <span>Ditemukan</span>
                            </h3>
                            <p class="text-xs text-gray-400 mt-1">Gunakan alat pencarian caption, filter, dan seleksi visual di bawah.</p>
                        </div>
                        <!-- PILIH SEMUA / CLEAR SELECTION PER HALAMAN -->
                        <div class="flex items-center space-x-2 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2">
                            <label class="flex items-center space-x-2 text-xs font-semibold text-gray-300 cursor-pointer select-none">
                                <input type="checkbox" id="selectAllCheckbox" onchange="toggleSelectAllOnPage(this)" class="w-4 h-4 rounded border-gray-700 text-pink-500 focus:ring-pink-500/30 bg-gray-900 cursor-pointer">
                                <span>Pilih Semua Halaman Ini</span>
                            </label>
                        </div>
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-2">
                        <!-- INPUT CARI CAPTION -->
                        <div class="flex items-center space-x-2 bg-gray-950 border border-gray-700 rounded-xl px-3 py-1.5 text-gray-300 relative w-full sm:w-auto">
                            <i data-lucide="search" class="w-4 h-4 text-pink-500"></i>
                            <input type="text" id="batchSearchInput" oninput="filterBatchByDateAndSearch()" placeholder="Cari caption..." class="bg-transparent text-xs focus:outline-none text-white w-full sm:w-32">
                        </div>

                        <!-- PENGURUTAN (SORTING) - UPDATE FILTER VIEWS TERBANYAK GLOBAL -->
                        <div class="flex items-center space-x-2 bg-gray-950 border border-gray-700 rounded-xl px-3 py-1.5 text-gray-300 relative">
                            <i data-lucide="arrow-down-up" class="w-4 h-4 text-purple-400"></i>
                            <select id="batchSortSelect" onchange="filterBatchByDateAndSearch()" class="bg-transparent text-xs font-semibold focus:outline-none cursor-pointer text-white border-none p-0 outline-none pr-6 appearance-none">
                                <option value="recent" selected>Terbaru (Asli)</option>
                                <option value="views_desc">Views Terbanyak (Semua Posting)</option>
