        // Memproses Username TikTok secara Perhalaman (Pagination)
        async function processUsernameVideos(isNewSearch = false) {
            let username = tiktokUsername.value.trim();
            if (username === "") {
                showError("Mohon masukkan username TikTok terlebih dahulu.");
                return;
            }

            if (username.startsWith('@')) {
                username = username.substring(1);
            }

            // Reset pagination state if this is a fresh search
            if (isNewSearch) {
                resetUsernamePagination();
                activeUsername = username;
                clearAllSelections(); // Hapus pilihan video saat mencari user baru
                document.getElementById('batchSortSelect').value = "recent";
            } else {
                if (selectAllCheckbox) selectAllCheckbox.checked = false;
            }

            const selectedLimit = parseInt(document.getElementById('usernameLimit').value) || 20;

            errorState.classList.add('hidden');
            batchResultState.classList.add('hidden');
            creatorProfileSection.classList.add('hidden');
            document.getElementById('usernamePagination').classList.add('hidden');
            loadingState.classList.remove('hidden');
            batchProgressBarContainer.classList.add('hidden');
            batchProgressText.classList.add('hidden');
            loadingMessage.innerText = `Menghubungkan ke API... Mengambil video Halaman ${usernameCurrentPage} dari @${activeUsername}...`;

            activeBatchResults = [];
            filteredBatchResults = [];
            batchResultsList.innerHTML = "";
            batchStartDateFilter.value = "";
            batchEndDateFilter.value = "";
            document.getElementById('batchSearchInput').value = "";
            resetFilterBtn.classList.add('hidden');

            let currentCursor = usernameCursors[usernameCurrentPage - 1] || "0";
            let accumulatedVideos = [];
            let hasMore = true;
            let loopCursor = currentCursor;

            try {
                const maxApiCount = 33;

                while (accumulatedVideos.length < selectedLimit && hasMore) {
                    const remainingNeeded = selectedLimit - accumulatedVideos.length;
                    const fetchCount = Math.min(maxApiCount, remainingNeeded);

                    loadingMessage.innerText = `Menghubungkan ke API... Mengambil video Halaman ${usernameCurrentPage} (${accumulatedVideos.length}/${selectedLimit}) dari @${activeUsername}...`;
                    
                    const response = await fetch(`https://www.tikwm.com/api/user/posts?unique_id=${encodeURIComponent(activeUsername)}&cursor=${loopCursor}&count=${fetchCount}`);
                    if (!response.ok) {
                        throw new Error(`Gagal menghubungi server pada halaman ${usernameCurrentPage}.`);
                    }
                    
                    const result = await response.json();
                    
                    if (result.code !== 0 || !result.data) {
                        throw new Error(result.msg || "Kreator tidak ditemukan atau profilnya berstatus privat.");
                    }

                    const videos = result.data.videos || [];
                    if (videos.length === 0) {
                        hasMore = false;
                        break;
                    }

                    accumulatedVideos = accumulatedVideos.concat(videos);
                    loopCursor = result.data.cursor;
                    hasMore = result.data.hasMore;

                    if (accumulatedVideos.length >= selectedLimit || !hasMore) {
                        break;
                    }

                    // Delay 300ms untuk menghindari rate limit API
                    await new Promise(resolve => setTimeout(resolve, 300));
                }

                if (accumulatedVideos.length === 0 && usernameCurrentPage === 1) {
                    throw new Error("Kreator ini belum membagikan postingan video apapun.");
                }

                accumulatedVideos.forEach((v, index) => {
                    const mappedData = {
                        id: v.video_id || v.id,
                        title: v.title,
                        cover: v.cover,
                        play: v.play,
                        wmplay: v.wmplay,
                        music: v.music,
                        create_time: v.create_time,
                        digg_count: v.digg_count || 0,
                        comment_count: v.comment_count || 0,
                        share_count: v.share_count || 0,
                        play_count: v.play_count || 0,
                        original_order: index, // Untuk mengembalikan ke sort asli jika dibutuhkan
                        author: v.author || {
                            unique_id: activeUsername,
                            nickname: activeUsername,
                            avatar: 'https://api.dicebear.com/7.x/bottts/svg?seed=' + activeUsername
                        }
                    };
                    activeBatchResults.push(mappedData);
                });

                // Tampilkan Profil Card Kreator
                if (accumulatedVideos.length > 0) {
                    const firstVideo = accumulatedVideos[0];
                    const userAvatarUrl = firstVideo.author ? firstVideo.author.avatar : '';
                    const userNicknameStr = firstVideo.author ? firstVideo.author.nickname : activeUsername;

                    document.getElementById('userAvatar').src = userAvatarUrl || `https://api.dicebear.com/7.x/bottts/svg?seed=${activeUsername}`;
                    document.getElementById('userNickname').innerText = userNicknameStr;
                    document.getElementById('userUniqueId').innerText = `@${activeUsername}`;
                    
                    // BARU: Panggil data follower untuk mode username
                    fetchUserStats(activeUsername).then(stats => {
                        const folCount = document.getElementById('userFollowers');
                        if (folCount) {
                            if (stats && stats.followerCount !== undefined) {
                                folCount.innerText = formatNumber(stats.followerCount);
                            } else {
                                folCount.innerText = "-";
                            }
                        }
                    });

                    document.getElementById('userSignature').innerText = `Menampilkan halaman ${usernameCurrentPage} (${activeBatchResults.length} video dimuat).`;
                    creatorProfileSection.classList.remove('hidden');
                }

                usernameHasMore = hasMore;
                if (usernameHasMore && loopCursor) {
                    usernameCursors[usernameCurrentPage] = loopCursor;
                }

                filterBatchByDateAndSearch();
                
                loadingState.classList.add('hidden');
                batchResultState.classList.remove('hidden');
                
                renderUsernamePaginationControls();

                batchResultState.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                showToast(`Sukses memuat Halaman ${usernameCurrentPage}!`, "sukses");

            } catch (err) {
                loadingState.classList.add('hidden');
                showError(err.message || "Gagal memproses username. Silakan ulangi beberapa saat lagi.");
            }
        }

        // PEMFILTERAN & PENGURUTAN (Views Terbanyak & Like Terbanyak)
        function filterBatchByDateAndSearch() {
            const startDateStr = batchStartDateFilter.value;
            const endDateStr = batchEndDateFilter.value;
            const searchKeyword = document.getElementById('batchSearchInput').value.toLowerCase().trim();
            const sortMethod = document.getElementById('batchSortSelect').value;
            
            batchResultsList.innerHTML = "";

            filteredBatchResults = activeBatchResults.filter(item => {
                // Check date range
                let dateMatch = true;
                const postDate = new Date(item.create_time * 1000);
                const postDateTime = new Date(postDate.getFullYear(), postDate.getMonth(), postDate.getDate()).getTime();

                if (startDateStr !== "") {
                    const [sYear, sMonth, sDay] = startDateStr.split('-').map(Number);
                    const startDateTime = new Date(sYear, sMonth - 1, sDay).getTime();
                    if (postDateTime < startDateTime) dateMatch = false;
                }

                if (endDateStr !== "") {
                    const [eYear, eMonth, eDay] = endDateStr.split('-').map(Number);
                    const endDateTime = new Date(eYear, eMonth - 1, eDay).getTime();
                    if (postDateTime > endDateTime) dateMatch = false;
                }

                // Check caption search
                let searchMatch = true;
                if (searchKeyword !== "") {
                    const caption = item.title ? item.title.toLowerCase() : "";
                    const username = item.author && item.author.unique_id ? item.author.unique_id.toLowerCase() : "";
                    searchMatch = caption.includes(searchKeyword) || username.includes(searchKeyword);
                }

                return dateMatch && searchMatch;
            });

            // Pengurutan (Sorting) Data Hasil Filter secara Global (Dari Semua Postingan Yang Dimuat)
            if (sortMethod === 'views_desc') {
                filteredBatchResults.sort((a, b) => b.play_count - a.play_count);
            } else if (sortMethod === 'likes_desc') {
                filteredBatchResults.sort((a, b) => b.digg_count - a.digg_count);
            } else {
                // Default ke "Terbaru"
                filteredBatchResults.sort((a, b) => b.create_time - a.create_time);
            }

            if (startDateStr !== "" || endDateStr !== "" || searchKeyword !== "") {
                resetFilterBtn.classList.remove('hidden');
            } else {
                resetFilterBtn.classList.add('hidden');
            }

            if (filteredBatchResults.length === 0) {
                const emptyItem = document.createElement('div');
                emptyItem.className = "p-12 text-center border-2 border-dashed border-gray-800 rounded-3xl text-gray-500 text-sm w-full col-span-full";
                emptyItem.innerHTML = `
                    <i data-lucide="filter-x" class="w-10 h-10 mx-auto mb-2 text-pink-500 opacity-60"></i>
                    <p class="font-bold text-gray-400">Tidak Ada Hasil Saringan</p>
                    <p class="text-xs text-gray-600 mt-1">Tidak ada postingan video yang sesuai dengan kriteria filter Anda.</p>
                `;
                batchResultsList.appendChild(emptyItem);
                lucide.createIcons();
            } else {
                updateSelectAllCheckboxState();
                filteredBatchResults.forEach(item => {
                    appendBatchResultItem(item);
                });
            }

            batchSuccessCount.innerText = `${filteredBatchResults.length} dari ${activeBatchResults.length} Video`;
            applyLayoutSettings(); 
        }

