        async function fetchTikTokData(url) {
            const apiUrl = `https://www.tikwm.com/api/?url=${encodeURIComponent(url)}`;
            const response = await fetch(apiUrl);
            if (!response.ok) throw new Error("Gagal terhubung dengan server pengurai.");
            const result = await response.json();
            if (result.code === 0 && result.data) {
                return result.data;
            } else {
                throw new Error(result.msg || "Tautan video salah, kedaluwarsa, atau privat.");
            }
        }

        // --- SISTEM SELEKSI VIDEO PREMIUM ---
        function toggleSelectVideo(id, checkboxElement) {
            const videoData = activeBatchResults.find(v => v.id === id);
            if (!videoData) return;

            if (checkboxElement.checked) {
                selectedVideos[id] = videoData;
            } else {
                delete selectedVideos[id];
            }

            const cardElement = document.getElementById(`card-${id}`);
            if (cardElement) {
                cardElement.classList.toggle('border-pink-500', checkboxElement.checked);
                cardElement.classList.toggle('ring-1', checkboxElement.checked);
                cardElement.classList.toggle('ring-pink-500/30', checkboxElement.checked);
                cardElement.classList.toggle('border-gray-800/80', !checkboxElement.checked);
            }

            updateSelectAllCheckboxState();
            updateSelectionBarUI();
        }

        function handleCardClick(e, id) {
            if (e.target.closest('button') || e.target.closest('input[type="checkbox"]') || e.target.closest('a')) {
                return;
            }
            const chk = document.getElementById(`chk-${id}`);
            if (chk) {
                chk.checked = !chk.checked;
                toggleSelectVideo(id, chk);
            }
        }

        function toggleSelectAllOnPage(checkbox) {
            filteredBatchResults.forEach(item => {
                const chk = document.getElementById(`chk-${item.id}`);
                if (chk) chk.checked = checkbox.checked;
                
                if (checkbox.checked) {
                    selectedVideos[item.id] = item;
                    const card = document.getElementById(`card-${item.id}`);
                    if (card) {
                        card.classList.add('border-pink-500', 'ring-1', 'ring-pink-500/30');
                        card.classList.remove('border-gray-800/80');
                    }
                } else {
                    delete selectedVideos[item.id];
                    const card = document.getElementById(`card-${item.id}`);
                    if (card) {
                        card.classList.remove('border-pink-500', 'ring-1', 'ring-pink-500/30');
                        card.classList.add('border-gray-800/80');
                    }
                }
            });
            updateSelectionBarUI();
        }

        function updateSelectAllCheckboxState() {
            if (!selectAllCheckbox || filteredBatchResults.length === 0) return;
            const allSelected = filteredBatchResults.every(item => selectedVideos[item.id] !== undefined);
            selectAllCheckbox.checked = allSelected;
        }

        function clearAllSelections() {
            selectedVideos = {};
