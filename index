        // Memproses Banyak Data Sekaligus (Batch)
        async function processBatchVideos() {
            const rawText = tiktokBatchUrls.value.trim();
            if (rawText === "") {
                showError("Mohon isi beberapa tautan atau ID video TikTok di textarea.");
                return;
            }

            const lines = rawText.split('\n')
                                 .map(line => dapatkanUrlValid(line))
                                 .filter(line => line !== "" && line.includes("tiktok.com"));

            if (lines.length === 0) {
                showError("Tidak ada tautan atau ID TikTok yang valid terdeteksi (satu per baris).");
                return;
            }

            errorState.classList.add('hidden');
            batchResultState.classList.add('hidden');
            creatorProfileSection.classList.add('hidden');
            document.getElementById('usernamePagination').classList.add('hidden');
            loadingState.classList.remove('hidden');
            batchProgressBarContainer.classList.remove('hidden');
            batchProgressText.classList.remove('hidden');

            activeBatchResults = [];
            filteredBatchResults = [];
            batchResultsList.innerHTML = "";
            batchStartDateFilter.value = "";
            batchEndDateFilter.value = "";
            document.getElementById('batchSearchInput').value = "";
            document.getElementById('batchSortSelect').value = "recent";
            resetFilterBtn.classList.add('hidden');
            clearAllSelections();

            const totalLinks = lines.length;
            let successCount = 0;

            for (let i = 0; i < totalLinks; i++) {
                const currentLink = lines[i];
                const displayIndex = i + 1;

                const progressPercentage = Math.round((displayIndex / totalLinks) * 100);
                batchProgressBar.style.width = `${progressPercentage}%`;
                batchProgressText.innerText = `Memproses ${displayIndex} dari ${totalLinks} data`;
                loadingMessage.innerText = `Sedang menganalisis baris ke-${displayIndex} ...`;

                try {
                    await new Promise(resolve => setTimeout(resolve, 600));
                    const data = await fetchTikTokData(currentLink);
                    
                    data.original_link = currentLink;
                    activeBatchResults.push(data);
                    successCount++;
                    
                    addToHistory(`@${data.author.unique_id}`, data.title || "Tautan Video", currentLink);
                } catch (err) {
                    console.error(`Gagal memproses baris ke-${displayIndex}:`, err);
                    appendBatchErrorItem(currentLink, err.message);
                }
            }

            loadingState.classList.add('hidden');
            
            if (activeBatchResults.length > 0) {
                filterBatchByDateAndSearch();
                batchResultState.classList.remove('hidden');
                batchResultState.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                showToast(`Selesai! ${successCount} video berhasil diproses.`, "sukses");
            } else {
                showError("Seluruh data gagal diproses. Silakan periksa kembali input Anda.");
            }
        }

