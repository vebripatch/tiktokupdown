        // Membaca Clipboard & Mengisinya langsung
        async function pasteToInput(elementId, btnId) {
            try {
                const target = document.getElementById(elementId);
                target.focus();
                const text = await navigator.clipboard.readText();
                if (text) {
                    target.value = text;
                    document.getElementById(btnId).classList.remove('hidden');
                    showToast("Teks disalin dari clipboard!", "sukses");
                }
            } catch (err) {
                showToast("Gagal mengakses clipboard. Gunakan paste manual.", "gagal");
            }
        }

        // Paste massal khusus untuk Textarea Batch
        async function pasteToTextarea() {
            try {
                tiktokBatchUrls.focus();
                const text = await navigator.clipboard.readText();
                if (text) {
                    const formattedText = text.replace(/ /g, '\n');
                    tiktokBatchUrls.value = formattedText;
                    clearBatchBtn.classList.remove('hidden');
                    showToast("Teks massal ditempel!", "sukses");
                }
            } catch (err) {
                showToast("Gagal mengakses clipboard. Gunakan paste manual.", "gagal");
            }
        }

        // Format angka statistik
        function formatNumber(num) {
            if (!num) return '0';
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num.toString();
        }

        // Memformat Unix Timestamp menjadi Tanggal & Waktu Lokal Indonesia
        function formatTimestampToDateTime(timestamp) {
            if (!timestamp) return "Tidak diketahui";
            const date = new Date(timestamp * 1000);
            const dateString = date.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
            const timeString = date.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            return `${dateString}, ${timeString}`;
        }

        // Mengubah Unix Timestamp ke YYYYMMDD
        function formatTimestampToShortDate(timestamp) {
            if (!timestamp) return "00000000";
            const date = new Date(timestamp * 1000);
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}${month}${day}`;
        }

        // Memvalidasi ID menjadi URL penuh
        function dapatkanUrlValid(input) {
            let str = input.trim();
            if (str === "") return "";
            if (/^\d+$/.test(str)) {
                return `https://www.tiktok.com/video/${str}`;
            }
            return str;
        }

