        // Setup observer for scrolling auto play
        function setupModalObserver() {
            if (currentModalObserver) currentModalObserver.disconnect();

            const options = {
                root: modalFeedContainer,
                rootMargin: '0px',
                threshold: 0.5 // Active when slide is at least 50% in viewport
            };

            currentModalObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    const video = entry.target.querySelector('video');
                    if (!video) return;

                    if (entry.isIntersecting) {
                        const playPromise = video.play();
                        if (playPromise !== undefined) {
                            playPromise.catch(e => { console.log("Auto-play blocked by browser. Interaction pending."); });
                        }
                    } else {
                        video.pause();
                        video.currentTime = 0;
                    }
                });
            }, options);

            const slides = modalFeedContainer.querySelectorAll(':scope > div');
            slides.forEach(slide => currentModalObserver.observe(slide));
        }

        function closeVideoModal() {
            videoModal.classList.add('opacity-0', 'pointer-events-none');
            document.body.style.overflow = ''; // Restore body scroll
            
            if (currentModalObserver) currentModalObserver.disconnect();
            
            // Cleanup memory and pause active clips
            const videos = modalFeedContainer.querySelectorAll('video');
            videos.forEach(v => {
                v.pause();
                v.removeAttribute('src'); 
                v.load();
            });
            
            setTimeout(() => { modalFeedContainer.innerHTML = ''; }, 300);
        }

        // --- SISTEM ANALISIS AI FYP (MENGGUNAKAN GEMINI API) ---
        async function fetchGeminiAnalysis(videoData) {
            const prompt = `Lakukan analisis mengapa video TikTok ini bisa masuk FYP atau mendapatkan banyak tayangan (views).
            Informasi Video:
            - Username Kreator: @${videoData.author.unique_id}
            - Caption/Judul: "${videoData.title || 'Tidak ada caption'}"
            - Tanggal Dibuat: ${formatTimestampToDateTime(videoData.create_time)}
            - Views (Dilihat): ${formatNumber(videoData.play_count)}
            - Likes (Suka): ${formatNumber(videoData.digg_count)}
            - Comments (Komentar): ${formatNumber(videoData.comment_count)}
            - Shares (Dibagikan): ${formatNumber(videoData.share_count)}
            
            Berikan analisis dalam 3 paragraf pendek dengan gaya bahasa yang asik (anak muda/konten kreator). Bahas kemungkinan adanya hook yang bagus, kualitas engagement, dan relevansi tren. Gunakan format HTML sederhana seperti <b> atau <ul><li> tanpa memunculkan blok markdown (\`\`\`) di hasilnya.`;

            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: "System instruction: Anda adalah analis algoritma TikTok dan konsultan FYP yang ahli, gaul, dan profesional." }] }
            };

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const response = await fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (!response.ok) throw new Error("Gagal mengambil respon dari AI.");
            const result = await response.json();
            return result.candidates?.[0]?.content?.parts?.[0]?.text || "Maaf, tidak ada hasil analisis yang keluar dari AI.";
        }

