        // Memantau input username
        tiktokUsername.addEventListener('input', () => {
            clearUserBtn.classList.toggle('hidden', tiktokUsername.value.trim() === "");
        });

        // Toggle Tab System
        function switchTab(tab) {
            currentTab = tab;
            const tabSingleBtn = document.getElementById('tabSingleBtn');
            const tabBatchBtn = document.getElementById('tabBatchBtn');
            const tabUsernameBtn = document.getElementById('tabUsernameBtn');
            const tabSingleContent = document.getElementById('tabSingleContent');
            const tabBatchContent = document.getElementById('tabBatchContent');
            const tabUsernameContent = document.getElementById('tabUsernameContent');

            // Reset Error dan Layouts
            errorState.classList.add('hidden');
            loadingState.classList.add('hidden');

            // Set Buttons Styling
            tabSingleBtn.className = "flex-1 pb-3 text-center font-bold text-sm border-b-2 " + (tab === 'single' ? 'border-pink-500 text-pink-500' : 'border-transparent text-gray-400 hover:text-gray-200') + " transition-all flex items-center justify-center space-x-2";
            tabBatchBtn.className = "flex-1 pb-3 text-center font-bold text-sm border-b-2 " + (tab === 'batch' ? 'border-pink-500 text-pink-500' : 'border-transparent text-gray-400 hover:text-gray-200') + " transition-all flex items-center justify-center space-x-2";
            tabUsernameBtn.className = "flex-1 pb-3 text-center font-bold text-sm border-b-2 " + (tab === 'username' ? 'border-pink-500 text-pink-500' : 'border-transparent text-gray-400 hover:text-gray-200') + " transition-all flex items-center justify-center space-x-2";

            // Toggle Contents
            if (tab === 'single') {
                tabSingleContent.classList.remove('hidden');
                tabBatchContent.classList.add('hidden');
                tabUsernameContent.classList.add('hidden');
                batchResultState.classList.add('hidden');
                if (activeData) resultState.classList.remove('hidden');
            } else if (tab === 'batch') {
                tabSingleContent.classList.add('hidden');
                tabBatchContent.classList.remove('hidden');
                tabUsernameContent.classList.add('hidden');
                resultState.classList.add('hidden');
                creatorProfileSection.classList.add('hidden');
                if (activeBatchResults.length > 0) batchResultState.classList.remove('hidden');
            } else if (tab === 'username') {
                tabSingleContent.classList.add('hidden');
                tabBatchContent.classList.add('hidden');
                tabUsernameContent.classList.remove('hidden');
                resultState.classList.add('hidden');
                if (activeBatchResults.length > 0) {
                    batchResultState.classList.remove('hidden');
                    creatorProfileSection.classList.remove('hidden');
