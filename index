        async function downloadFile(videoData, type, isSilent = false) {
            if (!videoData) return;

            let downloadUrl = "";
            let label = "Video No Watermark";
            let extension = "mp4";

            const fileDate = formatTimestampToShortDate(videoData.create_time);
            const username = videoData.author && videoData.author.unique_id ? `@${videoData.author.unique_id}` : 'tiktok_user';
            let baseFilename = `${fileDate} - ${username}`;

            if (type === 'no-wm') {
                downloadUrl = videoData.play;
                baseFilename += `_no_wm`;
                label = "Video Tanpa Watermark";
            } else if (type === 'wm') {
                downloadUrl = videoData.wmplay;
                baseFilename += `_wm`;
                label = "Video Dengan Watermark";
            } else if (type === 'audio') {
                downloadUrl = videoData.music;
                label = "Musik MP3";
                extension = "mp3";
            }

            const finalFilename = `${baseFilename}.${extension}`;
            if (!downloadUrl) {
                if (!isSilent) showToast("Tautan format ini tidak tersedia.", "gagal");
                return;
            }

            if (!isSilent) showToast(`Mengunduh ${label}...`, "proses");

            try {
                const response = await fetch(downloadUrl);
                if (!response.ok) throw new Error("CORS blocking");
                
                const blob = await response.blob();
                const blobUrl = URL.createObjectURL(blob);
                
                const a = document.createElement('a');
                a.href = blobUrl;
                a.download = finalFilename;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(blobUrl);
                
                if (!isSilent) showToast(`Sukses Mengunduh ${label}!`, "sukses");
            } catch (err) {
                console.warn("Direct URL download fallback.");
                if (!isSilent) showToast(`Membuka tautan unduh direct...`, "info");
                
                const a = document.createElement('a');
                a.href = downloadUrl;
                a.target = '_blank';
                a.download = finalFilename;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            }
        }

